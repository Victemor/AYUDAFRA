  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 583941753}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c36a64a340009fe46b365ab80dbbab8d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialController
  instructions:
  - id: intro
    text: Los fragmentos de memoria aparecen como gotas. Haz clic sobre ellas para
      verlos
    image: {fileID: 21300000, guid: b76a95d27ceceb4469be047b6277f336, type: 3}
  - id: movimiento
    text: "Mu\xE9vete con el mouse para explorar el entorno"
    image: {fileID: 21300000, guid: 8dc877bd6938181488f3fda4d03ceeb1, type: 3}
  - id: zoom
    text: "Ve el fragmento m\xE1s de cerca utilizando el scroll del mouse"
    image: {fileID: 21300000, guid: 9bdf201efbab7544c8a5ac5e1f0d6add, type: 3}
  - id: interaccion
    text: "Haz clic en los objetos interactuables para descubrir m\xE1s detalles
      de cada recuerdo."
    image: {fileID: 21300000, guid: b76a95d27ceceb4469be047b6277f336, type: 3}
  - id: observar
    text: "Cuando interact\xFAes, espera a que la escena termine antes de continuar.
      Pues ir leyendo la ventana de conciencia"
    image: {fileID: 0}
  - id: menu2
    text: "Con clic derecho puedes abrir su men\xFA, renombrarlas y conectar unos
      recuerdos con otros"
    image: {fileID: 21300000, guid: b76a95d27ceceb4469be047b6277f336, type: 3}
  - id: menu3
    text: Puedes renombrar cada fragmento,cuando termines usa la tecla Enter para
      confirmar
    image: {fileID: 21300000, guid: f05f095152c92a84aa42b89ec7ab2f7a, type: 3}
  - id: menu4
    text: Tambien puedes mover y organizar los fragmetos arrastrandolos
    image: {fileID: 21300000, guid: 8263f11e553fdc8488c4682a35e41d2c, type: 3}
  view: {fileID: 1140604128}
