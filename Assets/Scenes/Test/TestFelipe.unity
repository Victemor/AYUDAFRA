  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialController
  instructions:
  - id: intro
    text: Abre los fragmentos de memoria con click izqueirdo
    image: {fileID: 21300000, guid: 1e2c2830c8bf18748a9be754dea28cfd, type: 3}
  - id: movimiento
    text: Revisa cada espacio del fragmento moviendo el puntero mouse
    image: {fileID: 21300000, guid: 8dc877bd6938181488f3fda4d03ceeb1, type: 3}
  - id: zoom
    text: "Ve el fragmento m\xE1s de cerca utilizando el scroll del mouse"
    image: {fileID: 21300000, guid: 9bdf201efbab7544c8a5ac5e1f0d6add, type: 3}
  - id: interaccion
    text: "Busca y descubre m\xE1s detalles dando click izquierdo sobre los elementos
      interactivos."
    image: {fileID: 21300000, guid: 1e2c2830c8bf18748a9be754dea28cfd, type: 3}
  - id: observar
    text: "Observa con atenci\xF3n cada detalle. A la izquierda podr\xE1s ver la
      conciencia "
    image: {fileID: 0}
  - id: "Presta atenci\xF3n a cada detalle."
    text: "Busca y descubre m\xE1s detalles dando click izquierdo sobre los elementos
      interactivos."
    image: {fileID: 0}
  view: {fileID: 510906865}
  debugId: 
  debugOffset: 0
